<footer class="bg-wec-mid border-t border-wec-warm/40">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/images/wec-logo.png" alt="Western Events Center" class="h-10 w-auto" />
          <span class="font-display text-wec-cream text-lg">Western Events Center</span>
        </div>
        <p class="text-wec-muted text-sm leading-relaxed max-w-xs">
          Provo's authentic western venue for weddings, parties, and private events. Dancing, sound, and style, all in one hall.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-wec-cream font-semibold text-sm tracking-widest uppercase mb-5">Quick Links</h3>
        <ul class="space-y-3">
          <li><a href="#home" class="text-wec-muted hover:text-wec-red text-sm transition-colors">Home</a></li>
          <li><a href="#service" class="text-wec-muted hover:text-wec-red text-sm transition-colors">Service</a></li>
          <li><a href="#gallery" class="text-wec-muted hover:text-wec-red text-sm transition-colors">Gallery</a></li>
