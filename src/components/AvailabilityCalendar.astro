---
---

<div id="avail-calendar-simple" class="max-w-6xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <button id="avail-prev" aria-label="Previous month" class="w-11 h-11 flex items-center justify-center border border-wec-cream/20 text-wec-cream hover:border-wec-red hover:text-wec-red transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <h3 id="avail-month-label" class="font-display text-3xl sm:text-4xl text-wec-cream"></h3>
    <button id="avail-next" aria-label="Next month" class="w-11 h-11 flex items-center justify-center border border-wec-cream/20 text-wec-cream hover:border-wec-red hover:text-wec-red transition-colors">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>
  <div id="avail-grid" class="grid grid-cols-7 gap-2 sm:gap-3">
    <p class="col-span-7 text-center text-wec-text/60 text-sm py-12">Loading availability&hellip;</p>
  </div>
  <div class="flex items-center justify-center gap-6 mt-8 text-xs text-wec-text/60">
    <span class="flex items-center gap-2"><span class="w-3 h-3 bg-wec-warm border border-wec-cream/20"></span> Open</span>
    <span class="flex items-center gap-2"><span class="w-3 h-3 bg-wec-red/70"></span> Booked</span>
  </div>
</div>

<script>
  import { ymd, daysInMonth, firstWeekdayOfMonth, dateKeyInVenueTZ } from '../lib/calendar-dates';

  function initSimpleCalendar() {
    const root = document.getElementById('avail-calendar-simple');
    if (!root || root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const grid = root.querySelector('#avail-grid');
    const label = root.querySelector('#avail-month-label');
    const prevBtn = root.querySelector('#avail-prev');
    const nextBtn = root.querySelector('#avail-next');

    const todayKey = dateKeyInVenueTZ(new Date());
    const [todayYear, todayMonth] = todayKey.split('-').map(Number);
    let viewYear = todayYear;
    let viewMonth = todayMonth; // 1-12

    async function render() {
      if (label) {
        label.textContent = new Date(Date.UTC(viewYear, viewMonth - 1, 1)).toLocaleDateString('en-US', {
          month: 'long',
          year: 'numeric',
          timeZone: 'UTC',
        });
      }
      if (!grid) return;
      grid.innerHTML = '<p class="col-span-7 text-center text-wec-text/60 text-sm py-12">Loading availability&hellip;</p>';

      try {
        const res = await fetch(`/api/availability?year=${viewYear}&month=${viewMonth}`);
        if (!res.ok) throw new Error('bad response');
        const { days } = await res.json();

        const byDate = new Map(days.map((d: { date: string; booked: boolean }) => [d.date, d.booked]));

        const leading = firstWeekdayOfMonth(viewYear, viewMonth);
        const numDays = daysInMonth(viewYear, viewMonth);

        const labels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
        const cells: string[] = labels.map(
          (l) => `<div class="text-center text-wec-muted text-sm font-semibold uppercase pb-2">${l}</div>`
        );

        for (let i = 0; i < leading; i++) {
          cells.push(`<div class="aspect-[10/7]"></div>`);
        }

        for (let day = 1; day <= numDays; day++) {
          const key = ymd(viewYear, viewMonth, day);
          const booked = byDate.get(key);
          const isToday = key === todayKey;
          const ring = isToday ? ' ring-2 ring-wec-cream/70' : '';
          const base = 'aspect-[10/7] flex items-center justify-center text-base sm:text-2xl font-semibold transition-colors';
          if (booked) {
            cells.push(`<div class="${base} bg-wec-red/70 text-wec-cream${ring}" title="Booked">${day}</div>`);
          } else {
            cells.push(`<div class="${base} bg-wec-warm border border-wec-cream/10 text-wec-text${ring}" title="Open">${day}</div>`);
          }
        }

        // Trailing blanks to complete the last week row.
        const totalCells = leading + numDays;
        const trailing = (7 - (totalCells % 7)) % 7;
        for (let i = 0; i < trailing; i++) {
          cells.push(`<div class="aspect-[10/7]"></div>`);
        }

        grid.innerHTML = cells.join('');
      } catch {
        grid.innerHTML = '<p class="col-span-7 text-center text-wec-text/60 text-sm py-12">Availability is currently unavailable. Please call to check open dates.</p>';
      }
    }

    prevBtn?.addEventListener('click', () => {
      viewMonth -= 1;
      if (viewMonth < 1) {
        viewMonth = 12;
        viewYear -= 1;
      }
      render();
    });
    nextBtn?.addEventListener('click', () => {
      viewMonth += 1;
      if (viewMonth > 12) {
        viewMonth = 1;
        viewYear += 1;
      }
      render();
    });

    render();
  }

  initSimpleCalendar();
  document.addEventListener('astro:page-load', initSimpleCalendar);
</script>
