---

<div id="availability-calendar" class="max-w-xl mx-auto">
  <div id="avail-grid" class="grid grid-cols-7 gap-1.5 sm:gap-2">
    <p class="col-span-7 text-center text-wec-text/60 text-sm py-8">Loading availability&hellip;</p>
  </div>
  <div class="flex items-center justify-center gap-6 mt-6 text-xs text-wec-text/60">
    <span class="flex items-center gap-2"><span class="w-3 h-3 bg-wec-warm border border-wec-cream/20"></span> Open</span>
    <span class="flex items-center gap-2"><span class="w-3 h-3 bg-wec-red/70"></span> Booked</span>
  </div>
</div>

<script>
  async function loadAvailability() {
    const grid = document.getElementById('avail-grid');
    if (!grid) return;

    try {
      const res = await fetch('/api/availability');
      if (!res.ok) throw new Error('bad response');
      const { days } = await res.json();

      if (!Array.isArray(days) || days.length === 0) {
        grid.innerHTML = '<p class="col-span-7 text-center text-wec-text/60 text-sm py-8">Availability is currently unavailable. Please call to check open dates.</p>';
        return;
      }

      const byDate = new Map(days.map((d: { date: string; booked: boolean }) => [d.date, d.booked]));
      const first = new Date(days[0].date + 'T00:00:00');
      const last = new Date(days[days.length - 1].date + 'T00:00:00');

      // Pad to full weeks (Sun-Sat) so it reads like a real calendar.
      const gridStart = new Date(first);
      gridStart.setDate(gridStart.getDate() - gridStart.getDay());
      const gridEnd = new Date(last);
      gridEnd.setDate(gridEnd.getDate() + (6 - gridEnd.getDay()));

      const labels = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];
      const cells: string[] = labels.map(
        (l) => `<div class="text-center text-wec-muted text-xs font-semibold uppercase pb-2">${l}</div>`
      );

      const cursor = new Date(gridStart);
      while (cursor <= gridEnd) {
        const key = cursor.toISOString().slice(0, 10);
        const inRange = byDate.has(key);
        const booked = byDate.get(key);
        const dayNum = cursor.getDate();

        if (!inRange) {
          cells.push(`<div class="aspect-square"></div>`);
        } else if (booked) {
          cells.push(
            `<div class="aspect-square flex items-center justify-center bg-wec-red/70 text-wec-cream/90 text-sm font-semibold" title="Booked">${dayNum}</div>`
          );
        } else {
          cells.push(
            `<div class="aspect-square flex items-center justify-center bg-wec-warm border border-wec-cream/10 text-wec-text text-sm" title="Open">${dayNum}</div>`
          );
        }
        cursor.setDate(cursor.getDate() + 1);
      }

      grid.innerHTML = cells.join('');
    } catch {
      grid.innerHTML = '<p class="col-span-7 text-center text-wec-text/60 text-sm py-8">Availability is currently unavailable. Please call to check open dates.</p>';
    }
  }

  loadAvailability();
  document.addEventListener('astro:page-load', loadAvailability);
</script>
