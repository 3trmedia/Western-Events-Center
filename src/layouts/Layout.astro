---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = 'https://www.westerneventscenter.com/images/wec-hero.jpg',
  ogType = 'website',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />

    <ClientRouter />

    <!-- Preload slot for per-page LCP image hints -->
    <slot name="preload" />

    <!-- JSON-LD: default Organization — pages can inject additional schema via this slot -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EventVenue",
      "name": "Western Events Center",
      "url": "https://www.westerneventscenter.com",
      "telephone": "+1-385-204-3140",
      "email": "westerneventscenter@gmail.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1200 Towne Centre Blvd, Suite 1130",
        "addressLocality": "Provo",
        "addressRegion": "UT",
        "postalCode": "84601",
        "addressCountry": "US"
      }
    }
    </script>
    <slot name="schema" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/wec-logo.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Rye&family=Barlow:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-wec-dark text-wec-text font-body antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
